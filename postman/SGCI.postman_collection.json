            "body": {
              "mode": "raw",
              "raw": "{\n  \"identificacion\": \"{{estudianteIdentificacion}}\",\n  \"nombre\": \"Estudiante Postman Actualizado\",\n  \"correo\": \"{{estudianteCorreo}}\",\n  \"nombreUsuario\": \"{{estudianteNombreUsuario}}\",\n  \"clave\": \"password123\",\n  \"rolId\": 3,\n  \"estadoId\": 1\n}",
