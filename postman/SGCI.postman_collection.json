                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identificacion\": \"{{$timestamp}}\",\n  \"nombre\": \"Estudiante Postman\",\n  \"correo\": \"estudiante{{$timestamp}}@universidad.edu.co\",\n  \"nombreUsuario\": \"estudiante{{$timestamp}}\",\n  \"clave\": \"password123\",\n  \"rolId\": 3,\n  \"estadoId\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/usuarios"
          }
        },
