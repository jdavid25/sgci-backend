              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('usuarioId', json.id);",
                  "    pm.collectionVariables.set('estudianteNombreUsuario', json.nombreUsuario);",
                  "    pm.collectionVariables.set('estudianteIdentificacion', json.identificacion);",
                  "    pm.collectionVariables.set('estudianteCorreo', json.correo);",
                  "}"
                ]
              }
            }
